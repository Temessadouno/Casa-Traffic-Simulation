# --- CONFIGURATION MONGODB ---
# Utilise 'mongodb' car c'est le nom du service dans ton docker-compose
MONGO_URI=mongodb://mongodb:27017
DATABASE_NAME=simulation_db

# --- CONFIGURATION SUMO ---
# Dans Docker, le chemin est standardisé par l'installation apt-get
SUMO_HOME=/usr/share/sumo
SUMO_BINARY=sumo

# --- CONFIGURATION API ---
APP_NAME="TMT-Simulation-Accidents-IA"
DEBUG=True
PORT=8000